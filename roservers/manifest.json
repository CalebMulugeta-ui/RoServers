{
  "manifest_version": 3,
  "name": "RoServers",
  "version": "1.0.0",
  "description": "Choose your Roblox server by region for better ping.",
  "permissions": [
    "storage",
    "scripting",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://www.roblox.com/*",
    "https://games.roblox.com/*",
    "https://gamejoin.roblox.com/*",
    "https://thumbnails.roblox.com/*",
    "https://ipapi.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.roblox.com/games/*"],
      "js": ["regions.js", "geo.js", "ui.js", "welcome.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "RoServers",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["injector.js"],
      "matches": ["https://www.roblox.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
